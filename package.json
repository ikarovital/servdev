{
  "name": "new_automation",
  "version": "1.0.0",
  "description": "Automação E2E BDD com Cucumber e Allure Report",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:bdd": "cucumber-js",
    "test:bdd:allure": "cucumber-js",
    "test:allure": "playwright test",
    "allure:generate": "allure generate ./reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open ./reports/allure-report",
    "allure:serve": "allure serve ./reports/allure-results",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "keywords": ["e2e", "bdd", "cucumber", "playwright", "allure"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "allure-commandline": "^2.34.0",
    "allure-cucumberjs": "^3.5.0",
    "allure-js-commons": "^3.0.0",
    "allure-playwright": "^3.0.0",
    "playwright": "^1.58.2"
  }
}
